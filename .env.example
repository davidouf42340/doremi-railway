# ============================================================
# Dorémi Railway — Variables d'environnement
# À renseigner dans Railway > Variables (pas dans ce fichier)
# ============================================================

# ── OpenAI ──
# Votre clé API OpenAI (commence par sk-)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Shopify Webhook ──
# Secret de signature webhook Shopify
# Admin Shopify > Paramètres > Notifications > Webhooks > [votre webhook] > Secret
SHOPIFY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Shopify Admin API ──
# Domaine de votre boutique (sans https://)
SHOPIFY_SHOP_DOMAIN=votre-boutique.myshopify.com

# Token d'accès Admin API Shopify
# Admin Shopify > Paramètres > Apps et canaux > Développer des apps
# Créer une app privée avec permission : write_orders
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Railway ──
# PORT est géré automatiquement par Railway — ne pas modifier
PORT=3000
